# CivicPulse environment variables. Copy to .env.local for dev. Never commit real values.

# --- Gemini (Google AI Studio, free tier) — SERVER-SIDE ONLY ---
GEMINI_API_KEY=

# --- Firebase Admin SDK + Firestore (server-side) ---
# Auth uses Application Default Credentials (NO key file):
#   local dev  -> run `gcloud auth application-default login`
#   Cloud Run  -> the runtime service account (automatic)
FIREBASE_PROJECT_ID=

# --- Google Cloud Storage (issue + proof photos, Always-Free bucket) ---
# Accessed via the same ADC credentials above.
GCS_BUCKET=

# --- Firebase Web config (served to the client at runtime via /api/firebase-config) ---
# Public by design, but kept in server env (not the build/image) so it isn't committed.
FIREBASE_WEB_API_KEY=
FIREBASE_WEB_AUTH_DOMAIN=
FIREBASE_WEB_PROJECT_ID=
FIREBASE_WEB_APP_ID=
